# 复制为 .env 并填入你的 Key: cp .env.example .env

# ─── 云端(默认):DeepSeek 官方 API ───
# 文档: https://api-docs.deepseek.com/zh-cn/
DEEPSEEK_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-v4-flash
LLM_API_URL=https://api.deepseek.com/chat/completions

# ─── 本地(可选):Ollama 原生 /api/chat ───
# 开关一开,全部 NPC 决策/对话都走本地,不再访问云端
# 前置:`ollama pull qwen3.5:4b` && `ollama serve`
# 注意:URL 必须用 127.0.0.1(Node fetch 对 localhost 会走 IPv6,Ollama 只监听 IPv4)
# LLM_LOCAL_ENABLED=1
# LLM_LOCAL_MODEL=qwen3.5:4b
# LLM_LOCAL_URL=http://127.0.0.1:11434/api/chat
# LLM_LOCAL_THINK=0  # 关思考:Qwen3 开思考会慢到分钟级还常截断
